datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int    @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String @unique
  password   String
  role       String
  phone      String? @unique
  address    String?
  city       String?
  state      String?
  country    String?
  zip        String?
}
